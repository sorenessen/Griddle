<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="Griddle.App.Views.ToolbarWindow"
    Width="280"
    Height="60"
    CanResize="False"
    WindowDecorations="None"
    Topmost="True">

    <Border
        CornerRadius="10"
        Background="#DD2B2B2B"
        Padding="10">

        <StackPanel
            Orientation="Horizontal"
            Spacing="8">

            <Button
                Width="40"
                Height="40"
                Padding="0"
                Click="RedButton_Click"
                ToolTip.Tip="Pen">

                <Grid Width="22" Height="22">
                    <Line
                        StartPoint="5,17"
                        EndPoint="16,6"
                        Stroke="White"
                        StrokeThickness="3"
                        StrokeLineCap="Round"/>

                    <Ellipse
                        Width="5"
                        Height="5"
                        Fill="White"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,2,2,0"/>
                </Grid>

            </Button>

            <Button
                Width="40"
                Height="40"
                Padding="0"
                ToolTip.Tip="Blue">

                <Ellipse
                    Width="16"
                    Height="16"
                    Fill="DodgerBlue"/>

            </Button>

            <Button
                Width="40"
                Height="40"
                Padding="0"
                Click="HighlighterButton_Click"
                ToolTip.Tip="Highlighter">

                <Grid Width="22" Height="22">
                    <Rectangle
                        Width="8"
                        Height="16"
                        Fill="#FFF3C400"
                        RadiusX="2"
                        RadiusY="2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        RenderTransformOrigin="0.5,0.5">

                        <Rectangle.RenderTransform>
                            <RotateTransform Angle="-35"/>
                        </Rectangle.RenderTransform>

                    </Rectangle>

                    <Rectangle
                        Width="14"
                        Height="3"
                        Fill="#FFF3C400"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,1"/>
                </Grid>

            </Button>

            <Button
                Width="40"
                Height="40"
                Padding="0"
                ToolTip.Tip="Thickness">

                <Grid Width="22" Height="22">
                    <Line
                        StartPoint="3,7"
                        EndPoint="19,7"
                        Stroke="White"
                        StrokeThickness="2"
                        StrokeLineCap="Round"/>

                    <Line
                        StartPoint="3,15"
                        EndPoint="19,15"
                        Stroke="White"
                        StrokeThickness="5"
                        StrokeLineCap="Round"/>
                </Grid>

            </Button>

        </StackPanel>

    </Border>

</Window>